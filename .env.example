# ─────────────────────────────────────────────────────────────
# AI Product PLM Agent — environment variables
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NOT be committed.
# ─────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Airtable ──────────────────────────────────────────────────
# Personal access token — https://airtable.com/create/tokens
# Required scopes: data.records:write, schema.bases:read
AIRTABLE_TOKEN=pat...

# Base ID — visible in your base URL: airtable.com/<BASE_ID>/...
AIRTABLE_BASE_ID=app...

# ── Onshape (only required for CAD generation) ────────────────
# API keys — https://dev-portal.onshape.com/keys
ONSHAPE_ACCESS_KEY=on_...
ONSHAPE_SECRET_KEY=...

# Document IDs — copy from your Onshape document URL:
# https://cad.onshape.com/documents/<DID>/w/<WID>/e/<EID>
ONSHAPE_DID=...
ONSHAPE_WID=...
ONSHAPE_EID=...
